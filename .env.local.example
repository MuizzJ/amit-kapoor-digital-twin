# Anthropic — https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone — https://app.pinecone.io/ → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=ask-amit

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=TvgKRDHpNi1aqml8qok6

# Tavily (web search) — https://app.tavily.com/  — free tier: 1000 queries/month
# Leave blank to disable web search (app still works, just no live news context)
TAVILY_API_KEY=tvly-...

# Access control — comma-separated list
# Admin emails bypass all rate limits; allowed emails get 30 req/day
ADMIN_EMAILS=you@example.com
ALLOWED_EMAILS=amit@example.com,teammate@example.com
