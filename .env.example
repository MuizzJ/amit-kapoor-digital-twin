# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored and never committed.

# Anthropic — https://console.anthropic.com/ → Settings → API Keys
# If you see "credit balance too low" even after adding credit, create a key
# from inside the Default workspace (workspace-scoping bug).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Pinecone — https://app.pinecone.io/ → API Keys
# Create a serverless index named below with integrated inference
# (llama-text-embed-v2, 1024 dim, cosine metric). Namespace used: "books".
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=ask-amit

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
# Clone a voice in the ElevenLabs dashboard and paste its ID below.
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your-voice-id

# Tavily (web search) — https://app.tavily.com/ — free tier: 1000 queries/month
# Leave blank to disable web search (app still works, just no live news context).
TAVILY_API_KEY=tvly-...

# Access control — comma-separated email lists.
# ADMIN_EMAILS: full access to the /team dashboard, bypass all rate limits.
# ALLOWED_EMAILS: can use the public chat widget (30 questions + 30 listens/day).
ADMIN_EMAILS=you@example.com
ALLOWED_EMAILS=guest1@example.com,guest2@example.com
